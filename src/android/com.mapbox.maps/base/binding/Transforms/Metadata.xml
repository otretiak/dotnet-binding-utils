  <!-- Fix 2: ResponseReadStream missing ReadBytes method -->
  <!-- First check if IReadStream interface exists and requires ReadBytes -->
  <add-node path="//class[@name='ResponseReadStream']">
    <method 
      abstract="false" 
      deprecated="not deprecated" 
      final="false" 
      name="readBytes" 
      native="false" 
      return="byte[]" 
      static="false" 
      synchronized="false" 
      visibility="public">
    </method>
  </add-node>

  <!-- Alternative: If ReadBytes exists but with wrong signature -->
  <attr path="//class[@name='ResponseReadStream']/method[@name='readBytes']" name="return">byte[]</attr>

  <!-- Fix 3: IInitializer.Create return type issues -->
  <!-- Force all Initializer classes to return Java.Lang.Object from Create method -->
  <attr path="//class[@name='CoreInitializer']/method[@name='create' and count(parameter)=1 and parameter[1][@type='android.content.Context']]" name="managedReturn">Java.Lang.Object</attr>
  
  <attr path="//class[@name='BaseMapboxInitializer']/method[@name='create' and count(parameter)=1 and parameter[1][@type='android.content.Context']]" name="managedReturn">Java.Lang.Object</attr>
  
  <attr path="//class[@name='MapboxSDKCommonInitializerImpl']/method[@name='create' and count(parameter)=1 and parameter[1][@type='android.content.Context']]" name="managedReturn">Java.Lang.Object</attr>

  <!-- Generic fix for any other Initializer classes -->
  <attr path="//class[contains(@name, 'Initializer') and @extends='java.lang.Object']/method[@name='create' and count(parameter)=1]" name="managedReturn">Java.Lang.Object</attr>

