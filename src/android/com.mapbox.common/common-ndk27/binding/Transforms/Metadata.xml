<?xml version="1.0" encoding="UTF-8"?>
<metadata>
  <!-- Remove GoogleDeviceLocationProviderKt -->
  <remove-node path="//class[@name='GoogleDeviceLocationProviderKt']" />
  
  <!-- Remove GooglePlayServicesHelper references -->
  <remove-node path="//*[@return='com.mapbox.common.location.IGooglePlayServicesHelper']" />
  <remove-node path="//*[@type='com.mapbox.common.location.IGooglePlayServicesHelper']" />
  <remove-node path="//*[@extends='com.mapbox.common.location.IGooglePlayServicesHelper']" />

  <!-- Fix readBytes - DO NOT ADD IT, just map the existing one -->
  <attr path="//class[@name='ResponseReadStream']/method[@name='readBytes']" name="managedName">ReadBytes</attr>

  <!-- Fix Initializer return types -->
  <attr path="//class[contains(@name, 'Initializer')]/method[@name='create']" name="managedReturn">Java.Lang.Object</attr>
</metadata>