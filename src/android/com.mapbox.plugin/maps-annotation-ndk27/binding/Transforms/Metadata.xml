<?xml version="1.0" encoding="UTF-8"?>
<metadata>
	<!--
	  AnnotationManagerImpl has a generic type parameter L with classBound=Layer (from maps-style-ndk27).
	  Layer was dropped from maps-style-ndk27 by class-parse because Layer implements StyleLayerExtension
	  from base-ndk27 JAR which class-parse cannot see (no cross-JAR reference support).
	  As a result, the binding generator also cannot find Layer in the maps-style-ndk27 DLL reference and
	  rejects AnnotationManagerImpl entirely — which then causes CircleAnnotationManager etc. (which extend
	  AnnotationManagerImpl) to be rejected as well.
	  Fix: change L's classBound to java.lang.Object so the generator can process AnnotationManagerImpl
	  and its raw-type subclasses restored via <add-node> below.
	-->
	<attr
		path="/api/package[@name='com.mapbox.maps.plugin.annotation']/class[@name='AnnotationManagerImpl']/typeParameters/typeParameter[@name='L']"
		name="classBound">java.lang.Object</attr>
	<attr
		path="/api/package[@name='com.mapbox.maps.plugin.annotation']/class[@name='AnnotationManagerImpl']/typeParameters/typeParameter[@name='L']"
		name="jni-classBound">Ljava/lang/Object;</attr>
	<remove-node path="/api/package[@name='com.mapbox.maps.plugin.annotation']/class[@name='AnnotationManagerImpl']/typeParameters/typeParameter[@name='L']/genericConstraints" />
	<attr
		path="/api/package[@name='com.mapbox.maps.plugin.annotation.generated']/class[substring(@name, string-length(@name) - string-length('AnnotationOptions') + 1)]/method[@name='build' and count(parameter)=2]"
		name="managedName">DoBuild</attr>
	<attr
		path="/api/package[@name='com.mapbox.maps.plugin.annotation.generated']/class[substring(@name, string-length(@name) - string-length('Annotation') + 1)]/method[@name='getOffsetGeometry' and count(parameter)=2 and parameter[1][@type='com.mapbox.maps.plugin.delegates.MapCameraManagerDelegate'] and parameter[2][@type='com.mapbox.android.gestures.MoveDistancesObject']]"
		name="managedName">DoGetOffsetGeometry</attr>
	<attr
		path="/api/package[@name='com.mapbox.maps.plugin.annotation.generated']/class[substring(@name, string-length(@name) - string-length('AnnotationManager') + 1)]/method[@name='createLayer' and count(parameter)=0]"
		name="managedName">DoCreateLayer</attr>
	<attr
		path="/api/package[@name='com.mapbox.maps.plugin.annotation.generated']/class[substring(@name, string-length(@name) - string-length('AnnotationManager') + 1)]/method[@name='createDragLayer' and count(parameter)=0]"
		name="managedName">DoCreateDragLayer</attr>
	<!--
