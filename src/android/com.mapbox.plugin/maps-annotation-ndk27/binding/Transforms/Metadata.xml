				synthetic="false" visibility="public">
				<parameter name="delegateProvider" type="com.mapbox.maps.plugin.delegates.MapDelegateProvider" jni-type="Lcom/mapbox/maps/plugin/delegates/MapDelegateProvider;" />
				<parameter name="annotationConfig" type="com.mapbox.maps.plugin.annotation.AnnotationConfig" jni-type="Lcom/mapbox/maps/plugin/annotation/AnnotationConfig;" />
